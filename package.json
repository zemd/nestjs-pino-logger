{
  "name": "@zemd/nestjs-pino-logger",
  "version": "1.2.0",
  "description": "Nestjs logger based on pino",
  "type": "module",
  "scripts": {
    "build": "tsdown --minify",
    "changeset": "changeset",
    "release": "pnpm run build && changeset publish",
    "prepare": "husky",
    "lint": "eslint .",
    "preinstall": "npx only-allow pnpm"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "type": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zemd/nestjs-pino-logger.git"
  },
  "keywords": [
    "nestjs",
    "pino",
    "logger"
  ],
  "files": [
    "dist"
  ],
  "author": "Dmytro Zelenetskyi <dmytro.zelenetskyi@gmail.com>",
  "license": "BlueOak-1.0.0",
  "bugs": {
    "url": "https://github.com/zemd/nestjs-pino-logger/issues"
  },
  "homepage": "https://github.com/zemd/nestjs-pino-logger#readme",
  "dependencies": {
    "clean-stack": "6.0.0",
    "ms": "2.1.3"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@nestjs/common": "11.1.24",
    "@nestjs/config": "4.0.4",
    "@types/ms": "2.1.0",
    "@types/node": "25.9.1",
    "@zemd/eslint-ts": "3.0.3",
    "@zemd/tsconfig": "2.0.0",
    "eslint": "10.4.1",
    "husky": "9.1.7",
    "only-allow": "1.2.2",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.3",
    "tsdown": "0.22.1",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "@nestjs/common": "*",
    "@nestjs/config": "*",
    "pino": "*",
    "pino-pretty": "*"
  },
  "packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38"
}
