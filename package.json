{
  "name": "@zemd/nestjs-pino-logger",
  "version": "1.1.1",
  "description": "Nestjs logger based on pino",
  "type": "module",
  "scripts": {
    "build": "tsdown --minify",
    "changeset": "changeset",
    "release": "pnpm run build && changeset publish",
    "prepare": "husky",
    "lint": "eslint .",
    "preinstall": "npx only-allow pnpm"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "type": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zemd/nestjs-pino-logger.git"
  },
  "keywords": [
    "nestjs",
    "pino",
    "logger"
  ],
  "files": [
    "dist"
  ],
  "author": "Dmytro Zelenetskyi <dmytro.zelenetskyi@gmail.com>",
  "license": "BlueOak-1.0.0",
  "bugs": {
    "url": "https://github.com/zemd/nestjs-pino-logger/issues"
  },
  "homepage": "https://github.com/zemd/nestjs-pino-logger#readme",
  "dependencies": {
    "clean-stack": "6.0.0",
    "ms": "2.1.3"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@nestjs/common": "11.1.18",
    "@nestjs/config": "4.0.3",
    "@types/ms": "2.1.0",
    "@types/node": "25.5.2",
    "@zemd/eslint-ts": "3.0.1",
    "@zemd/tsconfig": "1.6.0",
    "eslint": "10.2.0",
    "husky": "9.1.7",
    "only-allow": "1.2.2",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.1",
    "tsdown": "0.21.7",
    "typescript": "6.0.2"
  },
  "peerDependencies": {
    "@nestjs/common": "*",
    "@nestjs/config": "*",
    "pino": "*",
    "pino-pretty": "*"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
